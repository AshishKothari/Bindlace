{
  "name": "@bindlace/wflow-runner-node",
  "version": "0.1.0",
  "description": "Bindlace Node runner: validate wflow artifacts, merge to IR, execute with Playwright or Selenium",
  "license": "Apache-2.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "bindlace": "./dist/cli.js",
    "wflow": "./dist/cli.js"
  },
  "files": [
    "dist",
    "schema"
  ],
  "scripts": {
    "build": "tsc && node scripts/copy-schemas.mjs",
    "dev": "tsc --watch",
    "bindlace": "node dist/cli.js",
    "wflow": "node dist/cli.js"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "playwright": "^1.49.0",
    "selenium-webdriver": "^4.40.0",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/selenium-webdriver": "^4.35.5",
    "typescript": "^5.7.2"
  }
}
