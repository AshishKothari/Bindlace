{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://bindlace.dev/schema/wdata.schema.json",
  "title": "wdata",
  "type": "object",
  "additionalProperties": false,
  "required": ["wflowSpecVersion", "kind", "data"],
  "properties": {
    "wflowSpecVersion": {
      "type": "integer",
      "const": 1
    },
    "kind": {
      "type": "string",
      "const": "wdata"
    },
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" }
      }
    },
    "log": {
      "type": "string",
      "description": "Optional message written to runner logs when this data file is loaded (${data...} allowed)"
    },
    "data": {
      "type": "object",
      "description": "Arbitrary JSON object tree; referenced as ${data.key} or ${data.a.b} in flows"
    }
  }
}
